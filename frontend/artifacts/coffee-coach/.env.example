# ADK backend base URL. The backend is the user's own local ADK api_server
# (started with: ./.venv/bin/adk api_server agents --port 8000 ...).
# This app's cloud preview cannot reach your machine's localhost -- run
# `pnpm --filter @workspace/coffee-coach run dev` locally and open it in a
# browser on the same machine as the ADK server to exercise the real flow.
VITE_API_BASE_URL=http://localhost:8000

# The ADK "app name" this frontend talks to (the folder name under `agents/`
# that you pass to `adk api_server agents`). Must match your local agents
# directory -- adjust if your agent module is named differently.
VITE_ADK_APP_NAME=agents
